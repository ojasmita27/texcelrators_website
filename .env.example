# Server
PORT=3000
NODE_ENV=development

# MongoDB
# For production, use MongoDB Atlas (recommended):
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/texcelerators?retryWrites=true&w=majority
# NOTE: If your password contains special characters (e.g. #, @, :, /), you must URL-encode it.
# Example: # becomes %23
# For local MongoDB:
MONGODB_URI=mongodb://127.0.0.1:27017/texcelerators

# Optional: run without installing MongoDB locally (dev only)
USE_IN_MEMORY_DB=false

# Prevent "hang forever" when MongoDB is unreachable
DB_SERVER_SELECTION_TIMEOUT_MS=10000
DB_CONNECT_TIMEOUT_MS=10000
MEMORY_DB_START_TIMEOUT_MS=60000

# Dashboard / business settings
MEMBER_TOTAL_FEE=13500

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Uploads
RECEIPT_UPLOAD_DIR=uploads/receipts

